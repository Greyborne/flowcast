// FlowCast — Prisma Schema
// Database: SQLite (MVP) → PostgreSQL (production)
// Note: SQLite does not support enums — using String with app-level validation instead.
// Valid IncomeType values: "W2" | "MONTHLY_RECURRING" | "AD_HOC"
// Valid BillType values:   "EXPENSE" | "TRANSFER" | "SAVINGS"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Pay Periods ──────────────────────────────────────────────────────────────
model PayPeriod {
  id             String   @id @default(cuid())
  startDate      DateTime
  endDate        DateTime
  paydayDate     DateTime
  openingBalance Float    @default(0)
  isGenerated    Boolean  @default(true)
  isClosed       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  incomeEntries   IncomeEntry[]
  billInstances   BillInstance[]
  balanceSnapshot BalanceSnapshot?

  @@index([paydayDate])
}

// ── Income Sources ───────────────────────────────────────────────────────────
// type: "W2" | "MONTHLY_RECURRING" | "AD_HOC"
model IncomeSource {
  id                   String    @id @default(cuid())
  name                 String
  type                 String    // "W2" | "MONTHLY_RECURRING" | "AD_HOC"
  defaultAmount        Float     @default(0)
  dayOfMonth           Int?
  startDate            DateTime
  endDate              DateTime?
  isActive             Boolean   @default(true)
  propagateOnReconcile Boolean   @default(false)
  sortOrder            Int       @default(9999)
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  incomeEntries IncomeEntry[]
}

// ── Income Entries ───────────────────────────────────────────────────────────
model IncomeEntry {
  id              String    @id @default(cuid())
  payPeriodId     String
  incomeSourceId  String
  projectedAmount Float
  actualAmount    Float?
  isReconciled    Boolean   @default(false)
  reconciledAt    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payPeriod    PayPeriod    @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  incomeSource IncomeSource @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([payPeriodId, incomeSourceId])
  @@index([payPeriodId])
  @@index([incomeSourceId])
}

// ── Bill Templates ───────────────────────────────────────────────────────────
// billType: "EXPENSE" | "TRANSFER" | "SAVINGS"
model BillTemplate {
  id              String   @id @default(cuid())
  name            String
  group           String
  billType        String   @default("EXPENSE") // "EXPENSE" | "TRANSFER" | "SAVINGS"
  dueDayOfMonth   Int?
  defaultAmount   Float    @default(0)
  isActive        Boolean  @default(true)
  isDiscretionary Boolean  @default(false)
  sortOrder       Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  billInstances  BillInstance[]
  monthlyAmounts BillMonthlyAmount[]

  @@unique([name])
}

// ── Bill Monthly Amounts ─────────────────────────────────────────────────────
model BillMonthlyAmount {
  id             String   @id @default(cuid())
  billTemplateId String
  year           Int
  month          Int
  amount         Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  billTemplate BillTemplate @relation(fields: [billTemplateId], references: [id], onDelete: Cascade)

  @@unique([billTemplateId, year, month])
  @@index([billTemplateId])
}

// ── Bill Instances ───────────────────────────────────────────────────────────
model BillInstance {
  id              String    @id @default(cuid())
  payPeriodId     String
  billTemplateId  String
  projectedAmount Float
  actualAmount    Float?
  isReconciled    Boolean   @default(false)
  isFrozen        Boolean   @default(false)
  reconciledAt    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payPeriod    PayPeriod    @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  billTemplate BillTemplate @relation(fields: [billTemplateId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([payPeriodId, billTemplateId])
  @@index([payPeriodId])
  @@index([billTemplateId])
}

// ── Balance Snapshots ────────────────────────────────────────────────────────
model BalanceSnapshot {
  id             String   @id @default(cuid())
  payPeriodId    String   @unique
  plannedBalance Float
  runningBalance Float
  actualBalance  Float    @default(0) // reconciled actuals only — no projected unreconciled amounts
  totalIncome    Float
  totalExpenses  Float
  isStale        Boolean  @default(false)
  computedAt     DateTime @default(now())

  payPeriod PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
}

// ── Reconciliation Log ───────────────────────────────────────────────────────
model ReconciliationLog {
  id              String   @id @default(cuid())
  resourceType    String
  resourceId      String
  action          String
  previousValue   Float?
  newValue        Float?
  periodsAffected Int      @default(1)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([createdAt])
}

// ── App Settings ─────────────────────────────────────────────────────────────
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Import Batches ────────────────────────────────────────────────────────────
// format: "OFX" | "CSV"
// status: "COMPLETED" | "PARTIAL" | "FAILED"
model ImportBatch {
  id            String   @id @default(cuid())
  filename      String
  format        String   // "OFX" | "CSV"
  importedAt    DateTime @default(now())
  totalCount    Int      @default(0)
  importedCount Int      @default(0)
  skippedCount  Int      @default(0) // duplicates skipped
  matchedCount  Int      @default(0) // auto-matched on import
  status        String   @default("COMPLETED") // "COMPLETED" | "PARTIAL" | "FAILED"

  transactions Transaction[]
}

// ── Transactions ──────────────────────────────────────────────────────────────
// source: "OFX" | "CSV" | "MANUAL"
// status: "UNMATCHED" | "MATCHED" | "IGNORED"
model Transaction {
  id              String    @id @default(cuid())
  importBatchId   String?
  dedupeKey       String?   @unique // fitId for OFX; SHA256 hash for CSV; null for manual
  date            DateTime
  amount          Float // negative = debit/expense, positive = credit/income
  description     String
  memo            String?
  transactionType String? // OFX TRNTYPE: DEBIT | CREDIT | INT | DIV | FEE | SRVCHG | DEP | ATM | POS | XFER | CHECK | PAYMENT | CASH | DIRECTDEP | DIRECTDEBIT | REPEATPMT | OTHER
  source          String    @default("OFX") // "OFX" | "CSV" | "MANUAL"
  status          String    @default("UNMATCHED") // "UNMATCHED" | "MATCHED" | "IGNORED"
  billInstanceId  String?
  incomeEntryId   String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  importBatch  ImportBatch?  @relation(fields: [importBatchId], references: [id])
  billInstance BillInstance? @relation(fields: [billInstanceId], references: [id])
  incomeEntry  IncomeEntry?  @relation(fields: [incomeEntryId], references: [id])

  @@index([date])
  @@index([status])
  @@index([importBatchId])
  @@index([billInstanceId])
  @@index([incomeEntryId])
}

// ── Auto Match Rules ──────────────────────────────────────────────────────────
// matchType: "CONTAINS" | "STARTS_WITH" | "REGEX"
// targetType: "BILL" | "INCOME"
model AutoMatchRule {
  id         String   @id @default(cuid())
  pattern    String
  matchType  String   @default("CONTAINS") // "CONTAINS" | "STARTS_WITH" | "REGEX"
  targetType String   // "BILL" | "INCOME"
  targetId   String   // billTemplateId or incomeSourceId
  priority   Int      @default(0) // higher = evaluated first
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, priority])
}
