// FlowCast — Prisma Schema
// Database: SQLite (MVP) → PostgreSQL (production)
// Note: SQLite does not support enums — using String with app-level validation instead.
// Valid IncomeType values: "W2" | "MONTHLY_RECURRING" | "AD_HOC"
// Valid BillType values:   "EXPENSE" | "TRANSFER" | "SAVINGS"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Pay Periods ──────────────────────────────────────────────────────────────
model PayPeriod {
  id             String   @id @default(cuid())
  startDate      DateTime
  endDate        DateTime
  paydayDate     DateTime
  openingBalance Float    @default(0)
  isGenerated    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  incomeEntries   IncomeEntry[]
  billInstances   BillInstance[]
  balanceSnapshot BalanceSnapshot?

  @@index([paydayDate])
}

// ── Income Sources ───────────────────────────────────────────────────────────
// type: "W2" | "MONTHLY_RECURRING" | "AD_HOC"
model IncomeSource {
  id                   String    @id @default(cuid())
  name                 String
  type                 String    // "W2" | "MONTHLY_RECURRING" | "AD_HOC"
  defaultAmount        Float     @default(0)
  dayOfMonth           Int?
  startDate            DateTime
  endDate              DateTime?
  isActive             Boolean   @default(true)
  propagateOnReconcile Boolean   @default(false)
  sortOrder            Int       @default(9999)
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  incomeEntries IncomeEntry[]
}

// ── Income Entries ───────────────────────────────────────────────────────────
model IncomeEntry {
  id              String    @id @default(cuid())
  payPeriodId     String
  incomeSourceId  String
  projectedAmount Float
  actualAmount    Float?
  isReconciled    Boolean   @default(false)
  reconciledAt    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payPeriod    PayPeriod    @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  incomeSource IncomeSource @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)

  @@unique([payPeriodId, incomeSourceId])
  @@index([payPeriodId])
  @@index([incomeSourceId])
}

// ── Bill Templates ───────────────────────────────────────────────────────────
// billType: "EXPENSE" | "TRANSFER" | "SAVINGS"
model BillTemplate {
  id              String   @id @default(cuid())
  name            String
  group           String
  billType        String   @default("EXPENSE") // "EXPENSE" | "TRANSFER" | "SAVINGS"
  dueDayOfMonth   Int?
  defaultAmount   Float    @default(0)
  isActive        Boolean  @default(true)
  isDiscretionary Boolean  @default(false)
  sortOrder       Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  billInstances  BillInstance[]
  monthlyAmounts BillMonthlyAmount[]

  @@unique([name])
}

// ── Bill Monthly Amounts ─────────────────────────────────────────────────────
model BillMonthlyAmount {
  id             String   @id @default(cuid())
  billTemplateId String
  year           Int
  month          Int
  amount         Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  billTemplate BillTemplate @relation(fields: [billTemplateId], references: [id], onDelete: Cascade)

  @@unique([billTemplateId, year, month])
  @@index([billTemplateId])
}

// ── Bill Instances ───────────────────────────────────────────────────────────
model BillInstance {
  id              String    @id @default(cuid())
  payPeriodId     String
  billTemplateId  String
  projectedAmount Float
  actualAmount    Float?
  isReconciled    Boolean   @default(false)
  isFrozen        Boolean   @default(false)
  reconciledAt    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payPeriod    PayPeriod    @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  billTemplate BillTemplate @relation(fields: [billTemplateId], references: [id], onDelete: Cascade)

  @@unique([payPeriodId, billTemplateId])
  @@index([payPeriodId])
  @@index([billTemplateId])
}

// ── Balance Snapshots ────────────────────────────────────────────────────────
model BalanceSnapshot {
  id             String   @id @default(cuid())
  payPeriodId    String   @unique
  plannedBalance Float
  runningBalance Float
  totalIncome    Float
  totalExpenses  Float
  isStale        Boolean  @default(false)
  computedAt     DateTime @default(now())

  payPeriod PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
}

// ── Reconciliation Log ───────────────────────────────────────────────────────
model ReconciliationLog {
  id              String   @id @default(cuid())
  resourceType    String
  resourceId      String
  action          String
  previousValue   Float?
  newValue        Float?
  periodsAffected Int      @default(1)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([createdAt])
}

// ── App Settings ─────────────────────────────────────────────────────────────
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
